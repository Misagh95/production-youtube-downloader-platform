# ─── App ───
APP_NAME=YouTube Downloader Platform
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_KEY=change-me-to-a-secure-random-string
PUBLIC_BASE_URL=http://localhost:8000

# ─── Download Limits ───
DOWNLOAD_DIR=./data/files
MAX_CONCURRENT_JOBS=3
MAX_FILESIZE_MB=512
MAX_DURATION_SECONDS=7200
LINK_EXPIRY_MINUTES=30
CLEANUP_INTERVAL_MINUTES=10

# ─── Telegram Bot ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_MAX_DIRECT_FILE_MB=49

# ─── yt-dlp / ffmpeg ───
YTDLP_OPTIONS_JSON={}
DEFAULT_VIDEO_QUALITY=1080p
DEFAULT_AUDIO_FORMAT=mp3
ENABLE_PLAYLISTS=false

# ─── Logging ───
LOG_LEVEL=INFO

# ─── Database (SQLite for jobs) ───
DATABASE_URL=sqlite+aiosqlite:///./data/jobs.db
